{{!
    @template videotimetab_resources/tab

    Template for the Resources tab.

    Context variables required for this template:
    * filelist  - array of file objects: name, url, size, mimetype, icon
    * hasfiles  - boolean: true when filelist is non-empty
    * editurl   - URL to the mod form (fallback link, only for editing teachers when JS fails)
    * canedit   - boolean: true when the current user can manage resources
    * cmid      - course module id, used by JS to open the file-picker modal

    Example context (json):
    {
        "canedit": true,
        "editurl": "#",
        "cmid": 1,
        "hasfiles": true,
        "filelist": [
            {
                "name": "example.pdf",
                "url": "#",
                "size": "1.2 MB",
                "extension": "PDF",
                "icon": "/path/to/icon.png"
            }
        ]
    }
}}
<div class="videotimetab_resources p-3">

    {{# canedit }}
    <div class="d-flex justify-content-end mb-2">
        <a href="{{ editurl }}"
           data-action="edit-resources"
           data-cmid="{{ cmid }}"
           class="btn btn-sm btn-outline-secondary">
            <i class="fa fa-pencil" aria-hidden="true"></i>
            {{# str }} edit {{/ str }}
        </a>
    </div>
    {{/ canedit }}

    {{# hasfiles }}
    <div class="list-group">
        {{# filelist }}
        <a href="{{ url }}"
           class="list-group-item list-group-item-action d-flex align-items-center"
           target="_blank"
           rel="noopener noreferrer">
            <img src="{{ icon }}" alt="" width="24" height="24" class="mr-2 flex-shrink-0">
            <span class="flex-grow-1">{{ name }}</span>
            <small class="text-muted ml-2 flex-shrink-0">{{ extension }} &middot; {{ size }}</small>
        </a>
        {{/ filelist }}
    </div>
    {{/ hasfiles }}
    {{^ hasfiles }}
    <p class="text-muted">{{# str }} noresources, videotimetab_resources {{/ str }}</p>
    {{/ hasfiles }}

</div>
