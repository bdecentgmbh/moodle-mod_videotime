{{!
    @template videotimetab_interaction/tab

    This template for tab panel

    Variables required for this template:

    Variables optional for this template:
    * title - The video title

    Example context (json):
    {
        "title": "Poodles"
    }

}}
<div class="videotimetab_interaction" data-contextid="{{ contextid }}">
    <div class="col-12">
        <h5>{{ title }}</h5>
    </div>
    {{^ canedit }}
    <button
        class="btn btn-secondary"
        type="button"
        data-action="edit"
    >
       {{# str }} edit, core {{/ str }}
    </button>
    {{/ canedit }}
    <div data-region="interactions-{{ id }}"></div>
</div>
{{# js }}
    require(['videotimetab_interaction/interaction'], function(Interaction) {
        Interaction.initialize();
    });
{{/ js }}
